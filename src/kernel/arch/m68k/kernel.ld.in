
#include <kconfig.h>

ENTRY(_start)
EXTERN(_start)

MEMORY
{
  ram : ORIGIN = CONFIG_KERNEL_BASE, LENGTH = CONFIG_KERNEL_MEM_SIZE
}

SECTIONS
{
  .text : {
    __kernel_start = .;

    *(.text.start)
    *(.text)
  } > ram

  .rodata : {
    *(.rodata)
  } > ram

  .data : {
    *(.data)
  } > ram

  __bss_start = .;
  .bss : {
    *(.bss)
  } > ram
  __bss_end = .;

  /* Stack must be page aligned */
  . = ALIGN(CONFIG_PAGE_SIZE);
  __boot_stack_bottom = .;
  .stack (NOLOAD) : {
    FILL(0x00);
    . = . + CONFIG_BOOT_STACK_SIZE;
  } > ram
  __boot_stack_top = .;
  __kernel_end = .;

#if defined(CONFIG_MEM_LAYOUT_AUTO)

#if defined(CONFIG_MEMDISK)
  /* Memdisk must be page-aligned */
  . = ALIGN(CONFIG_PAGE_SIZE);
  __memdisk0_start = .;
  
  /* TODO: implement actual memdisk section filled with memdisk image if wanted */
  . = . + CONFIG_MEMDISK0_SIZE;

  /* Just for debug reasons, not used in code */
  __memdisk0_end = .;
#endif

  /* Pages themself must be page-aligned */
  . = ALIGN(CONFIG_PAGE_SIZE);
  __pages_start = .;
  __pages_end = ORIGIN(ram) + LENGTH(ram);

#endif
}
