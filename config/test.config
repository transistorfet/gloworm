#
# Automatically generated file; DO NOT EDIT.
# Gloworm Configuration
#
CONFIG_ARCH_M68K=y
# CONFIG_ARCH_TESTAPP is not set
CONFIG_ARCH="m68k"

#
# General setup
#
# CONFIG_CC_OPTIMIZE_FOR_PERFORMANCE is not set
# CONFIG_CC_OPTIMIZE_FOR_PERFORMANCE_O3 is not set
CONFIG_CC_OPTIMIZE_FOR_SIZE=y

#
# Kernel Configuration
#
CONFIG_KERNEL=y

#
# Architecture setup
#
CONFIG_M68K=y
CONFIG_GCC_PREFIX="m68k-linux-gnu-"
CONFIG_NUM_CPUS=1
# CONFIG_MC68010 is not set
CONFIG_MC68030=y
CONFIG_M68K_USER_MODE=y
CONFIG_MMU=y
CONFIG_PAGE_SIZE_256=y
# CONFIG_PAGE_SIZE_512 is not set
# CONFIG_PAGE_SIZE_1K is not set
# CONFIG_PAGE_SIZE_2K is not set
# CONFIG_PAGE_SIZE_4K is not set
# CONFIG_PAGE_SIZE_8K is not set
# CONFIG_PAGE_SIZE_16K is not set
# CONFIG_PAGE_SIZE_32K is not set
CONFIG_CPU_BIG_ENDIAN=y

#
# Device drivers
#
CONFIG_ATA=y
CONFIG_ATA_BASE=0xff800000
CONFIG_MEM=y

#
# Network Intefaces
#
CONFIG_SLIP=y
CONFIG_TTY=y
CONFIG_TTY_68681=y
CONFIG_TTY_68681_BASE=0x00700001
CONFIG_TTY_68681_INTVEC=64
CONFIG_TTY_68681_CLOCKSOURCE=y
CONFIG_TTY_68681_GPIO_LEDS=y

#
# File systems
#
CONFIG_MSDOS_PARTITION=y
CONFIG_MINIX_FS=y
CONFIG_PATH_MAX=1024

#
# Memory management
#
CONFIG_KERNEL_BASE=0x100000
CONFIG_PAGES_START=0x120000
CONFIG_PAGES_END=0x300000
CONFIG_PAGE_SIZE=256

#
# Networking support
#
CONFIG_NET=y
CONFIG_INETV4=y

#
# Network Intefaces
#

#
# Process and thread options
#
CONFIG_USER_STACK_SIZE=16384
CONFIG_KERNEL_STACK_SIZE=2048
CONFIG_RESCHEDULE_PERIOD_MS=100

#
# Miscellaneous options
#
# CONFIG_SHELL_IN_KERNEL is not set
# CONFIG_LOG_LEVEL_NOTICE is not set
# CONFIG_LOG_LEVEL_INFO is not set
CONFIG_LOG_LEVEL_DEBUG=y
# CONFIG_LOG_LEVEL_TRACE is not set
CONFIG_DEBUG=y
CONFIG_DEBUG_LEDS=y

#
# Commands
#
CONFIG_COMMANDS=y
CONFIG_CMD_SH=y
CONFIG_SHELL_WITH_UTILS=y
CONFIG_CMD_TESTS=y

#
# Bootloader setup
#
CONFIG_BOOT=y

#
# Monitor setup
#
CONFIG_MONITOR=y
CONFIG_SINGLE_AM29F040=y
# CONFIG_DUAL_AM29F040 is not set
# CONFIG_MONITOR_TESTCMDS is not set
