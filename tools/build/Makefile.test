
bare-tests-load		:= $(patsubst %,%.test.load, $(tests-obj-y))
host-tests-run		:= $(patsubst %,%.test.run, $(tests-obj-y))

bare-tests-common-deps	:= tests/entry.o tests/printk.o src/monitor/tty_68681.o $(bare-tests-extra-y)
bare-tests-common-deps	:= $(addprefix $(OUTPUT),$(bare-tests-common-deps))

PHONY += tests
tests: $(config-h) $(tests-subdir-y) $(host-tests-run)

PHONY += bare-tests
bare-tests: $(config-h) $(tests-subdir-y) $(bare-tests-load)

%.test.run: %.test.host
	./$<

%.test.host: HOST_CFLAGS += -DHOST_TARGET -DHOST_TEST
%.test.host: %.host.o $(tests-extra-y)
	$(cmd_host_ld_elf)

%.host.o: %.c
	$(cmd_host_cc_o)

%.test.load: ccflags-y += $(firmware-ccflags-y)
%.test.load: %.bin
	tools/make-load-file $< $@ $(LOAD_ARGS)

%.test.bin: %.o $(bare-tests-common-deps)
	$(cmd_ld_bin)

