
bare-tests-load		:= $(patsubst %,%.test.load, $(tests-obj-y))
host-tests-run		:= $(patsubst %,%.test.run, $(tests-obj-y))

host-tests-extra-y	+= $(patsubst %.o,%.host.o, $(tests-extra-y))
bare-tests-extra-y	+= $(tests-extra-y)

host-tests-auto-extra	:= tests/printk.host.o
host-tests-auto-extra	:= $(addprefix $(OUTPUT),$(host-tests-auto-extra))
host-tests-common-deps	:= $(host-tests-auto-extra) $(host-tests-extra-y)

bare-tests-auto-extra	:= tests/entry.o tests/printk.o src/monitor/tty_68681.o
bare-tests-auto-extra	:= $(addprefix $(OUTPUT),$(bare-tests-auto-extra))
bare-tests-common-deps	:= $(bare-tests-auto-extra) $(bare-tests-extra-y) $(libex-obj-y)

PHONY += tests
tests: $(config-h) $(tests-subdir-y) $(host-tests-run)

PHONY += bare-tests
bare-tests: $(config-h) $(tests-subdir-y) $(bare-tests-load)

%.test.run: %.test.host
	./$<

%.test.host: HOST_CFLAGS += -DHOST_TARGET -DHOST_TEST
%.test.host: %.host.o $(host-tests-common-deps)
	$(cmd_host_ld_elf)

%.host.o: %.c
	$(cmd_host_cc_o)

%.test.load: ccflags-y += $(firmware-ccflags-y)
%.test.load: %.bin
	tools/make-load-file $< $@ $(LOAD_ARGS)

%.test.bin: %.o $(bare-tests-common-deps)
	$(cmd_ld_bin)

